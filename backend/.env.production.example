# ⚠️ TEMPLATE - NÃO PREENCHA COM CREDENCIAIS REAIS
# Use este arquivo como referência apenas

PORT=5005
NODE_ENV=production
FRONTEND_URL=https://projeto-frts-app.vercel.app

# MongoDB Atlas - USE VARIÁVEIS DE AMBIENTE DO RAILWAY
# NÃO PREENCHA ESTE ARQUIVO COM CREDENCIAIS REAIS
MONGODB_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/[database]?retryWrites=true&w=majority

# P1-ATLAS-CUTOVER-01: o ATLAS é a fonte oficial de verdade. Em produção mantenha
# USE_MEMORY_STORAGE=false (o memory-storage.json é apenas fallback de emergência/dev,
# nunca destino de escrita oficial). SKIP_MONGODB_RETRIES=false para garantir conexão.
USE_MEMORY_STORAGE=false
SKIP_MONGODB_RETRIES=false

# Anthropic Claude API - REQUERIDO para extração de datasheets com visão
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-[sua-chave-aqui]

ADMIN_API_KEY=[seu-admin-api-key]
SOLARMARKET_API_KEY=[sua-api-key]
SOLARMARKET_API_URL=https://api.solarmarket.com.br
