PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# String de conexão do cluster oficial. Use a connection string SRV do Atlas.
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/forte_solar
# Bypass do Atlas → grava em data/memory-storage.json. Deixe FALSE para persistência real.
# (true só para desenvolvimento offline; reseta concessionária p/ monofásico e some com INPE)
USE_MEMORY_STORAGE=false
# Opcional: sobrescreve os resolvers DNS antes de conectar. Necessário em máquinas onde o
# resolver do SO não resolve a busca SRV de mongodb+srv:// (erro `querySrv ECONNREFUSED`).
# No-op quando ausente. Ex.: 8.8.8.8,1.1.1.1
MONGODB_DNS_SERVERS=

# Admin
ADMIN_API_KEY=dev-key-123

# IA — Extração de Datasheets (obrigatório para upload de PDF e visão de imagens)
# Obtenha em: https://console.anthropic.com/api_keys
# Necessário para: Claude Vision, extração de garantias em imagens, selos, análise de equipamentos
# Você pode usar tanto em desenvolvimento quanto em produção (mesmo workspace)
ANTHROPIC_API_KEY=sk-ant-seu-valor-aqui

# SolarMarket Integration
SOLARMARKET_API_KEY=6059:iQANRfzf2ykzC46raDUw8bx41Xm2qtOQSRhtTp7v
SOLARMARKET_API_URL=https://api.solarmarket.com.br
